// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?
  refreshToken String?
  provider     String   @default("local")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  role         String

  userTier String? @default("standard")

  firstName String
  lastName  String

  emailVerified    Boolean   @default(false)
  resetOTP         String?
  resetOTPExpiry   DateTime?
  verificationCode String?

  gender  String?
  dob     String?
  address String?

  username String @unique

  phoneNumber String?
  city        String?
  state       String?
  country     String?

  image      String?
  joinedDate String?

  isDeleted           Boolean @default(false)
  onboardingCompleted Boolean @default(false)

  interests String[]

  admin               Admin?
  vendorProfile       VendorProfile?
  events              Event[]
  orders              Order[]
  tickets             Ticket[]
  wallet              VendorWallet?
  withdrawalRequests  WithdrawalRequest[]
  reservations        Reservation[]
  posts               Post[]
  venueOwnerProfile   VenueOwnerProfile?
  waitlistEntries     ReservationWaitlist[]
  cart                Cart?
  ecomOrders          EcomOrder[]
}

enum AdminPosition {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

model Admin {
  id        String        @id @default(uuid())
  userId    String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  position  AdminPosition @default(ADMIN)
  user      User          @relation(fields: [userId], references: [id])
}

model VendorProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  brandName String
  brandBio  String?
  website   String?
  instagram String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

// ─── Events & Ticketing ───────────────────────────────────────────────────────

enum EventCategory {
  CONCERT
  PRIVATE_DINING
  ART_EXHIBITION
  NIGHTLIFE
  FESTIVAL
  WELLNESS
  SPORT
  OTHER
}

enum EventStatus {
  DRAFT
  LIVE
  SOLD_OUT
  CANCELLED
  ENDED
  PENDING_REVIEW
  REJECTED
}

model Event {
  id           String        @id @default(uuid())
  title        String
  slug         String        @unique
  description  String?
  category     EventCategory
  status       EventStatus   @default(DRAFT)
  coverImage   String?
  date         DateTime
  doorsOpen    String
  venueName    String
  venueAddress String?
  city         String?
  dressCode    String?
  isMemberOnly    Boolean     @default(false)
  rejectionReason String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  ticketTiers TicketTier[]
  orders      Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketTier {
  id          String  @id @default(uuid())
  eventId     String
  name        String
  description String?
  price       Int // in kobo (100 kobo = ₦1)
  quantity    Int
  sold        Int     @default(0)

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Orders & Tickets ─────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id        String      @id @default(uuid())
  reference String      @unique
  userId    String
  eventId   String
  status    OrderStatus @default(PENDING)

  subtotal   Int // in kobo
  serviceFee Int // in kobo
  total      Int // in kobo

  paystackReference String?
  paystackData      Json?

  user    User        @relation(fields: [userId], references: [id])
  event   Event       @relation(fields: [eventId], references: [id])
  items   OrderItem[]
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id           String @id @default(uuid())
  orderId      String
  ticketTierId String
  quantity     Int
  unitPrice    Int // in kobo, price locked at time of purchase

  order      Order      @relation(fields: [orderId], references: [id])
  ticketTier TicketTier @relation(fields: [ticketTierId], references: [id])
  tickets    Ticket[]
}

model Ticket {
  id          String    @id @default(uuid())
  code        String    @unique // unique QR code value
  orderId     String
  orderItemId String
  userId      String
  isUsed      Boolean   @default(false)
  usedAt      DateTime?

  order     Order     @relation(fields: [orderId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Vendor Wallet & Payouts ──────────────────────────────────────────────────

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  TRANSFERRED
}

model VendorWallet {
  id        String   @id @default(uuid())
  vendorId  String   @unique
  balance   Int      @default(0) // in kobo
  updatedAt DateTime @updatedAt

  vendor User @relation(fields: [vendorId], references: [id])
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  vendorId      String
  amount        Int // in kobo
  bankCode      String
  accountNumber String
  accountName   String
  status        WithdrawalStatus @default(PENDING)
  paystackRef   String?
  note          String? // admin note on approve/reject
  createdAt     DateTime         @default(now())
  resolvedAt    DateTime?

  vendor User @relation(fields: [vendorId], references: [id])
}

// ─── Venue Owner Wallet & Payouts ─────────────────────────────────────────────

model VenueOwnerWallet {
  id          String   @id @default(uuid())
  ownerId     String   @unique // VenueOwnerProfile.id
  balance     Int      @default(0) // withdrawable balance in kobo
  totalEarned Int      @default(0) // lifetime earnings in kobo
  updatedAt   DateTime @updatedAt

  owner       VenueOwnerProfile      @relation(fields: [ownerId], references: [id])
  withdrawals VenueOwnerWithdrawal[]
}

model VenueOwnerWithdrawal {
  id            String           @id @default(uuid())
  walletId      String
  amount        Int              // in kobo
  bankCode      String
  accountNumber String
  accountName   String
  status        WithdrawalStatus @default(PENDING)
  paystackRef   String?
  note          String?          // admin note on approve/reject
  createdAt     DateTime         @default(now())
  resolvedAt    DateTime?

  wallet VenueOwnerWallet @relation(fields: [walletId], references: [id])
}

// ─── Membership Applications ──────────────────────────────────────────────────

enum MembershipTier {
  GOLD
  BLACK
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model MembershipApplication {
  id          String            @id @default(uuid())
  fullName    String
  email       String
  phone       String
  occupation  String
  city        String
  tier        MembershipTier
  referral    String?
  message     String?
  status      ApplicationStatus @default(PENDING)
  paystackRef String? // set when payment link is generated
  paidAt      DateTime? // set when payment is verified

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Vibe Report (Media / Blog) ───────────────────────────────────────────────

enum PostCategory {
  NEWS
  BLOG
  LIFESTYLE
  MUSIC
  EVENTS
  OTHER
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id          String       @id @default(uuid())
  title       String
  slug        String       @unique
  excerpt     String?
  body        String
  coverImage  String?
  category    PostCategory @default(OTHER)
  status      PostStatus   @default(DRAFT)
  tags        String[]
  isFeatured  Boolean      @default(false)
  publishedAt DateTime?
  authorId    String
  author      User         @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── The Black Book (Reservations) ────────────────────────────────────────────

enum VenueCategory {
  RESTAURANT
  BAR
  NIGHTCLUB
  LOUNGE
  ROOFTOP_BAR
  BEACH_CLUB
  POOL_CLUB
  SPA
  WELLNESS_CENTER
  PRIVATE_MEMBERS_CLUB
  PRIVATE_DINING
  CIGAR_LOUNGE
  WINE_BAR
  COCKTAIL_BAR
  JAZZ_CLUB
  LIVE_MUSIC_VENUE
  SPORTS_BAR
  HOOKAH_LOUNGE
  POP_UP
  YACHT
  OTHER
}

enum VenueStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  LIVE
  SUSPENDED
}

enum BookingMode {
  INSTANT  // auto-confirm on payment
  REQUEST  // venue must approve after payment
}

enum SpaceType {
  TABLE
  SECTION
  PRIVATE_ROOM
  BAR_SEATING
  OUTDOOR
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum DepositType {
  NONE
  FLAT
  PERCENTAGE_OF_MIN_SPEND
}

enum ReservationStatus {
  PENDING_PAYMENT
  PENDING_APPROVAL
  CONFIRMED
  REJECTED
  MODIFIED
  CANCELLED_BY_GUEST
  CANCELLED_BY_VENUE
  COMPLETED
  NO_SHOW
}

enum ReservationPaymentStatus {
  PENDING
  PAID
  REFUNDED_FULL
  REFUNDED_PARTIAL
  FAILED
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CLAIMED
  EXPIRED
}

// Venue owner profile — links a User to venue ownership + bank/payout details
model VenueOwnerProfile {
  id            String  @id @default(uuid())
  userId        String  @unique
  businessName  String
  businessEmail String?
  businessPhone String?

  // Paystack subaccount for split payments
  paystackSubaccountCode String?
  bankCode               String?
  accountNumber          String?
  accountName            String?
  isVerified             Boolean @default(false)

  user   User             @relation(fields: [userId], references: [id])
  venues Venue[]
  wallet VenueOwnerWallet?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Venue {
  id          String        @id @default(uuid())
  slug        String        @unique
  name        String
  description String?
  category    VenueCategory
  status      VenueStatus   @default(PENDING_REVIEW)
  bookingMode BookingMode   @default(INSTANT)

  ownerId String
  owner   VenueOwnerProfile @relation(fields: [ownerId], references: [id])

  // Location
  address String
  city    String
  state   String?
  country String  @default("Nigeria")

  // Media
  coverImage String?
  images     String[]

  // Contact
  phone     String?
  email     String?
  instagram String?
  website   String?

  // Platform commission (percent, e.g. 10 = 10%) — can be negotiated per venue
  platformFeePercent Int @default(10)

  // Rejection
  rejectionReason String?

  isDeleted Boolean @default(false)

  spaces         VenueSpace[]
  operatingHours VenueOperatingHours[]
  sessions       VenueSession[]
  blockedDates   VenueBlockedDate[]
  policy         ReservationPolicy?
  reservations   Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Individual bookable spaces within a venue (tables, VIP sections, private rooms, etc.)
model VenueSpace {
  id          String    @id @default(uuid())
  venueId     String
  name        String    // e.g. "Table 7", "VIP Section A", "The Cave Room"
  type        SpaceType
  capacity    Int       // max guests
  description String?
  minSpend    Int?      // in kobo, optional
  images      String[]
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)

  venue        Venue              @relation(fields: [venueId], references: [id])
  reservations ReservationSpace[]
  blockedDates VenueBlockedDate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Operating hours per day of week
model VenueOperatingHours {
  id        String    @id @default(uuid())
  venueId   String
  dayOfWeek DayOfWeek
  openTime  String    // "18:00"
  closeTime String    // "02:00"
  isClosed  Boolean   @default(false)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, dayOfWeek])
}

// Named booking sessions within a venue's operating hours
// e.g. "Early Dinner" 18:00–21:00, "Late Night" 21:00–02:00
model VenueSession {
  id                  String      @id @default(uuid())
  venueId             String
  name                String
  startTime           String      // "18:00"
  endTime             String      // "21:00"
  slotDurationMinutes Int         @default(60)
  daysOfWeek          DayOfWeek[]
  isActive            Boolean     @default(true)

  venue        Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Blocked dates — spaceId null = whole venue blocked
model VenueBlockedDate {
  id      String   @id @default(uuid())
  venueId String
  spaceId String?
  date    DateTime @db.Date
  reason  String?

  venue Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  space VenueSpace? @relation(fields: [spaceId], references: [id])

  createdAt DateTime @default(now())
}

// Cancellation and deposit policy — one per venue
model ReservationPolicy {
  id      String @id @default(uuid())
  venueId String @unique

  // Deposit settings
  depositType    DepositType @default(NONE)
  depositAmount  Int?        // in kobo — used when depositType = FLAT
  depositPercent Int?        // 0–100 — used when depositType = PERCENTAGE_OF_MIN_SPEND

  // Cancellation refund tiers (hours before booking time)
  // >= fullRefundHoursThreshold  → 100% refund
  // >= partialRefundHoursThreshold → partialRefundPercent% refund
  // < partialRefundHoursThreshold  → 0% refund (no refund)
  fullRefundHoursThreshold    Int? // e.g. 48
  partialRefundHoursThreshold Int? // e.g. 24
  partialRefundPercent        Int? // e.g. 50

  // How many hours before the booking time modifications are allowed
  modificationAllowedHoursBefore Int @default(24)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

// The booking itself
model Reservation {
  id        String @id @default(uuid())
  reference String @unique // e.g. EKR-A1B2C3

  venueId   String
  userId    String
  sessionId String?

  date      DateTime @db.Date
  timeSlot  String   // e.g. "19:00"
  partySize Int

  status ReservationStatus @default(PENDING_PAYMENT)

  notes           String?
  specialRequests String?

  venueNote String?
  adminNote String?

  // Financials — all in kobo
  depositAmount Int @default(0)
  platformFee   Int @default(0)
  venuePayout   Int @default(0)

  confirmedAt DateTime?
  cancelledAt DateTime?
  completedAt DateTime?

  venue   Venue         @relation(fields: [venueId], references: [id])
  user    User          @relation(fields: [userId], references: [id])
  session VenueSession? @relation(fields: [sessionId], references: [id])

  spaces  ReservationSpace[]
  payment ReservationPayment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Which space(s) are booked in a reservation (supports booking multiple spaces)
model ReservationSpace {
  id            String @id @default(uuid())
  reservationId String
  spaceId       String

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  space       VenueSpace  @relation(fields: [spaceId], references: [id])
}

// Payment record linked to a reservation
model ReservationPayment {
  id            String @id @default(uuid())
  reservationId String @unique

  paystackReference String?
  paystackData      Json?

  amount         Int // total paid in kobo
  platformFee    Int // Ekovibe's cut in kobo
  venuePayout    Int // venue's cut in kobo
  refundedAmount Int @default(0) // total refunded in kobo

  status ReservationPaymentStatus @default(PENDING)

  paidAt     DateTime?
  refundedAt DateTime?

  reservation Reservation @relation(fields: [reservationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Waitlist — guests queue for a full time slot
model ReservationWaitlist {
  id        String        @id @default(uuid())
  venueId   String
  userId    String
  sessionId String?
  date      DateTime      @db.Date
  timeSlot  String
  partySize Int
  status    WaitlistStatus @default(WAITING)

  notifiedAt     DateTime? // when we sent the "spot available" email
  claimExpiresAt DateTime? // guest has until this time to claim

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── The Vault (E-commerce) ───────────────────────────────────────────────────

enum ProductCategory {
  CLOTHING
  ACCESSORIES
  LIFESTYLE
  BEAUTY
  FOOD
  OTHER
}

enum EcomOrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum VaultPaymentMethod {
  PAYSTACK
  PAY_ON_DELIVERY
}

enum EcomPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Product {
  id          String          @id @default(uuid())
  name        String
  slug        String          @unique
  description String
  price       Int             // base price in kobo
  images      String[]
  category    ProductCategory @default(OTHER)
  isAvailable Boolean         @default(true)

  variants   ProductVariant[]
  orderItems EcomOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  name      String  // e.g. "Red / Large"
  price     Int?    // override in kobo; null = use product base price
  stock     Int     @default(0)

  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems EcomOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  variantId String
  quantity  Int    @default(1)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, variantId])
}

model DeliveryZone {
  id    String @id @default(uuid())
  state String @unique
  fee   Int    // in kobo
}

model EcomOrder {
  id            String             @id @default(uuid())
  userId        String
  status        EcomOrderStatus    @default(PENDING)
  paymentMethod VaultPaymentMethod
  paymentStatus EcomPaymentStatus  @default(PENDING)
  paystackRef   String?

  totalAmount Int // items subtotal in kobo
  deliveryFee Int // in kobo

  // Delivery address snapshot
  recipientName String
  phone         String
  addressLine   String
  city          String
  state         String

  trackingNumber String?
  note           String?

  user  User            @relation(fields: [userId], references: [id])
  items EcomOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EcomOrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  variantId String
  quantity  Int

  // Snapshots at time of order
  productName String
  variantName String
  price       Int // kobo per unit

  order   EcomOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
}
