// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?
  refreshToken String?
  provider     String   @default("local")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  role         String

  userTier String? @default("standard")

  firstName String
  lastName  String

  emailVerified    Boolean   @default(false)
  resetOTP         String?
  resetOTPExpiry   DateTime?
  verificationCode String?

  gender  String?
  dob     String?
  address String?

  username String @unique

  phoneNumber String?
  city        String?
  state       String?
  country     String?

  image      String?
  joinedDate String?

  isDeleted           Boolean @default(false)
  onboardingCompleted Boolean @default(false)

  interests String[]

  admin               Admin?
  vendorProfile       VendorProfile?
  events              Event[]
  orders              Order[]
  tickets             Ticket[]
  wallet              VendorWallet?
  withdrawalRequests  WithdrawalRequest[]
  reservations        Reservation[]
}

enum AdminPosition {
  SUPER_ADMIN
  ADMIN
  MODERATOR
}

model Admin {
  id        String        @id @default(uuid())
  userId    String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  position  AdminPosition @default(ADMIN)
  user      User          @relation(fields: [userId], references: [id])
}

model VendorProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  brandName String
  brandBio  String?
  website   String?
  instagram String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

// ─── Events & Ticketing ───────────────────────────────────────────────────────

enum EventCategory {
  CONCERT
  PRIVATE_DINING
  ART_EXHIBITION
  NIGHTLIFE
  FESTIVAL
  WELLNESS
  SPORT
  OTHER
}

enum EventStatus {
  DRAFT
  LIVE
  SOLD_OUT
  CANCELLED
  ENDED
  PENDING_REVIEW
  REJECTED
}

model Event {
  id           String        @id @default(uuid())
  title        String
  slug         String        @unique
  description  String?
  category     EventCategory
  status       EventStatus   @default(DRAFT)
  coverImage   String?
  date         DateTime
  doorsOpen    String
  venueName    String
  venueAddress String?
  city         String?
  dressCode    String?
  isMemberOnly    Boolean     @default(false)
  rejectionReason String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  ticketTiers TicketTier[]
  orders      Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketTier {
  id          String  @id @default(uuid())
  eventId     String
  name        String
  description String?
  price       Int // in kobo (100 kobo = ₦1)
  quantity    Int
  sold        Int     @default(0)

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Orders & Tickets ─────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id        String      @id @default(uuid())
  reference String      @unique
  userId    String
  eventId   String
  status    OrderStatus @default(PENDING)

  subtotal   Int // in kobo
  serviceFee Int // in kobo
  total      Int // in kobo

  paystackReference String?
  paystackData      Json?

  user    User        @relation(fields: [userId], references: [id])
  event   Event       @relation(fields: [eventId], references: [id])
  items   OrderItem[]
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id           String @id @default(uuid())
  orderId      String
  ticketTierId String
  quantity     Int
  unitPrice    Int // in kobo, price locked at time of purchase

  order      Order      @relation(fields: [orderId], references: [id])
  ticketTier TicketTier @relation(fields: [ticketTierId], references: [id])
  tickets    Ticket[]
}

model Ticket {
  id          String    @id @default(uuid())
  code        String    @unique // unique QR code value
  orderId     String
  orderItemId String
  userId      String
  isUsed      Boolean   @default(false)
  usedAt      DateTime?

  order     Order     @relation(fields: [orderId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Vendor Wallet & Payouts ──────────────────────────────────────────────────

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  TRANSFERRED
}

model VendorWallet {
  id        String   @id @default(uuid())
  vendorId  String   @unique
  balance   Int      @default(0) // in kobo
  updatedAt DateTime @updatedAt

  vendor User @relation(fields: [vendorId], references: [id])
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  vendorId      String
  amount        Int // in kobo
  bankCode      String
  accountNumber String
  accountName   String
  status        WithdrawalStatus @default(PENDING)
  paystackRef   String?
  note          String? // admin note on approve/reject
  createdAt     DateTime         @default(now())
  resolvedAt    DateTime?

  vendor User @relation(fields: [vendorId], references: [id])
}

// ─── Membership Applications ──────────────────────────────────────────────────

enum MembershipTier {
  GOLD
  BLACK
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

model MembershipApplication {
  id          String            @id @default(uuid())
  fullName    String
  email       String
  phone       String
  occupation  String
  city        String
  tier        MembershipTier
  referral    String?
  message     String?
  status      ApplicationStatus @default(PENDING)
  paystackRef String? // set when payment link is generated
  paidAt      DateTime? // set when payment is verified

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── The Black Book (Reservations) ────────────────────────────────────────────

enum VenueType {
  RESTAURANT
  NIGHTCLUB
  LOUNGE
  PRIVATE_DINING
  ROOFTOP
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

model Venue {
  id          String    @id @default(uuid())
  name        String
  description String?
  type        VenueType
  address     String
  city        String
  coverImage  String?
  instagram   String?
  website     String?
  isActive    Boolean   @default(true)

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reservation {
  id        String            @id @default(uuid())
  venueId   String
  userId    String
  date      DateTime
  time      String
  partySize Int
  notes     String?
  status    ReservationStatus @default(PENDING)
  adminNote String?

  venue Venue @relation(fields: [venueId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
